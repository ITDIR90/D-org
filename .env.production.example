# Скопируйте: cp .env.production.example .env
# Пароль БД — тот же, что POSTGRES_PASSWORD ниже и в docker-compose.prod.yml

APP_NAME=Digital-органайзер
APP_SHORT_NAME=D-органайзер
APP_ENV=production

# openssl rand -hex 32
SECRET_KEY=замените_на_случайную_строку
JWT_EXPIRE_MINUTES=480

POSTGRES_PASSWORD=замените_на_сложный_пароль_бд
DATABASE_URL=postgresql+asyncpg://helpdesk:замените_на_сложный_пароль_бд@db:5432/helpdesk

# Публичный адрес сайта (для CORS). После SSL укажите https://ваш-домен
# Если заходите по IP: http://123.45.67.89
BACKEND_CORS_ORIGINS=https://dorg.example.com

# Домен для SSL (Let's Encrypt). A-запись домена → IP сервера. На один IP сертификат не выдают.
DOMAIN=dorg.example.com
CERTBOT_EMAIL=admin@example.com
# true — тестовый сертификат (для проверки, браузер будет ругаться)
CERTBOT_STAGING=false

# Оставьте пустым — API пойдёт через тот же домен (/api/...).
# Не используйте http://localhost:8000 в production.
VITE_API_URL=

HTTP_PORT=80
HTTPS_PORT=443

EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=false

TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=false

MAX_ENABLED=false
MAX_GATEWAY_URL=https://max.mebel-alivia.ru/api/v1/send
MAX_GATEWAY_TOKEN=

PUSH_ENABLED=true
EXPO_ACCESS_TOKEN=

GEMINI_API_KEY=
AI_PROVIDER=auto
AI_ENABLED=false
AI_MODEL=

DEFAULT_SUPERADMIN_EMAIL=admin@example.com
DEFAULT_SUPERADMIN_PASSWORD=замените_после_первого_входа

# Защита от повторной отправки одного и того же сообщения (секунды)
DUPLICATE_MESSAGE_WINDOW_SECONDS=30

# API для внешних систем (1С)
INTEGRATION_API_ENABLED=true
# Сгенерируйте: openssl rand -hex 32
INTEGRATION_API_KEY=замените_на_случайный_ключ
# ID пользователя-автора заявок из 1С (создайте в разделе «Пользователи»)
INTEGRATION_USER_ID=1
