# Скопируйте: cp .env.production.example .env
# Пароль БД — тот же, что POSTGRES_PASSWORD ниже и в docker-compose.prod.yml

APP_NAME=Digital-органайзер
APP_SHORT_NAME=D-органайзер
APP_ENV=production

# openssl rand -hex 32
SECRET_KEY=замените_на_случайную_строку
JWT_EXPIRE_MINUTES=480

POSTGRES_PASSWORD=замените_на_сложный_пароль_бд
DATABASE_URL=postgresql+asyncpg://helpdesk:замените_на_сложный_пароль_бд@db:5432/helpdesk

# Публичный адрес сайта (для CORS). Без слэша в конце.
BACKEND_CORS_ORIGINS=https://dorg.example.com

# URL API для сборки frontend. Оставьте пустым, если сайт и API на одном домене.
VITE_API_URL=

HTTP_PORT=80

EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=false

TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=false

GEMINI_API_KEY=
AI_PROVIDER=auto
AI_ENABLED=false
AI_MODEL=

DEFAULT_SUPERADMIN_EMAIL=admin@example.com
DEFAULT_SUPERADMIN_PASSWORD=замените_после_первого_входа
